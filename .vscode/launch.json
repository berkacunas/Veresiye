{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {   // Python Debugger: Current File
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {   // Python Debugger: Current File with Args
            "name":"Python Debugger: Current File with Args",
            "type":"debugpy",
            "request":"launch",
            "program":"${file}",
            "console":"integratedTerminal",
            "args": []
        },
        {   // Python Debugger: Module
            "name": "Python Debugger: Module",
            "type": "debugpy",
            "request": "launch",
            "module": "veresiye.main",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {   // Debug Tests (Pytest - Current File)
            "name": "Debug Tests (Pytest - Current File)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "-s",           // display print() outputs
                "-v",           // verbose
                "${file}"       // file in use
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}